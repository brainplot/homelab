{% set fmt = '{:15}    {}' %}
{% set self_ip = ansible_facts['default_ipv4']['address'] | default('127.0.1.1', true) %}
{{ fmt.format('127.0.0.1', 'localhost') }}
{{ fmt.format('::1', 'localhost ip6-localhost ip6-loopback') }}
{{ fmt.format('ff02::1', 'ip6-allnodes') }}
{{ fmt.format('ff02::2', 'ip6-allrouters') }}

{{ fmt.format(self_ip, [ansible_facts['fqdn'], ansible_facts['hostname']] | unique | join(' ')) }}
